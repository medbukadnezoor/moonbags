# ==============================================================================
# MoonBags — environment template
# ==============================================================================
# Copy this file to `.env` (`cp .env.example .env`) or better, run:
#     npm run setup
# which walks you through every field with live validation and can
# auto-generate a wallet + auto-detect your Telegram chat_id.
#
# NEVER commit `.env` — it's in .gitignore for a reason.
# ==============================================================================

# === REQUIRED ===
# Jupiter Ultra API — https://developers.jup.ag/portal
JUP_API_KEY=
# Helius RPC — https://dashboard.helius.dev
HELIUS_API_KEY=
# Base58-encoded Solana keypair secret. Leave blank while DRY_RUN=true.
# The setup wizard can generate a fresh keypair for you.
PRIV_B58=

# === RPC ===
RPC_URL=https://beta.helius-rpc.com?api-key=${HELIUS_API_KEY}

# === TRADING PARAMS (backtest-optimized defaults) ===
BUY_SIZE_SOL=0.02
MAX_CONCURRENT_POSITIONS=10

# Trailing take-profit:
#   armed once PnL >= ARM_PCT (0.5 = +50%)
#   exits when drawdown from peak >= TRAIL_PCT (0.55 = -55% off high)
ARM_PCT=0.5
TRAIL_PCT=0.55

# Hard stop-loss: exits when PnL <= -STOP_PCT (0.4 = -40%)
STOP_PCT=0.4

# Time-based exit in seconds (effectively disabled — let LLM/trail decide)
MAX_HOLD_SECS=99999999999999999

# === ALERT FILTERS (0 = disabled) ===
# The LLM advisor does most filtering; leave these at 0 unless you know why.
MAX_ALERT_AGE_MINS=0
MIN_LIQUIDITY_USD=0
MIN_SCORE=0
MAX_RUG_RATIO=0
MAX_BUNDLER_PCT=0
MAX_TOP10_PCT=0
REQUIRE_RISING_LIQ=false

# === POLLING (ms) ===
SCG_POLL_MS=3000
PRICE_POLL_MS=3000

# === EXECUTION ===
# Fallback slippage for lite-v1 quotes. Ultra uses RTSE automatically.
SLIPPAGE_BPS=2500

# LEAVE TRUE while testing. Set to false to submit real swaps.
DRY_RUN=true

# === DASHBOARD ===
DASHBOARD_PORT=8787

# === TELEGRAM (control + alerts) ===
# Create a bot via @BotFather and paste the token. The setup wizard
# auto-detects your chat_id — or find it manually by messaging your bot
# and visiting https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === LLM EXIT ADVISOR (optional) ===
# When true, MiniMax M2.7 manages exits for armed positions using live
# on-chain data. Toggle live from Telegram with /llm.
# Referral link (10% off): https://platform.minimax.io/subscribe/token-plan?code=K0Q2oDUiwK&source=link
LLM_EXIT_ENABLED=false
MINIMAX_API_KEY=

# === MILESTONE ALERTS ===
# Send a Telegram notification (with inline sell button) the first time
# a position crosses each PnL threshold. Edit live via /settings.
MILESTONES_ENABLED=true
# Comma-separated list of PnL % thresholds. Default covers 2x / 3x / 6x / 11x.
MILESTONE_PCTS=100,200,500,1000
