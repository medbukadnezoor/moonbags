{
  "name": "memeautobuy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "tsx src/_setup.ts",
    "doctor": "tsx src/_doctor.ts",
    "install:onchainos": "curl -sSL https://raw.githubusercontent.com/okx/onchainos-skills/main/install.sh | sh",
    "dev": "node --dns-result-order=ipv4first --import tsx --watch src/main.ts",
    "start:dry": "DRY_RUN=true node --dns-result-order=ipv4first --import tsx src/main.ts",
    "start": "node --dns-result-order=ipv4first --import tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "pm2:start:dry": "mkdir -p logs && pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "pm2 restart moonbags --update-env",
    "pm2:stop": "pm2 stop moonbags",
    "pm2:delete": "pm2 delete moonbags",
    "pm2:status": "command -v pm2 >/dev/null 2>&1 && (pm2 status moonbags || pm2 status) || echo \"pm2 not installed\"",
    "pm2:logs": "pm2 logs moonbags",
    "pm2:tail": "pm2 logs moonbags --lines 120 --nostream",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup systemd -u opc --hp /home/opc",
    "up": "npm run pm2:start:dry",
    "re": "npm run pm2:restart",
    "down": "npm run pm2:stop",
    "ps": "npm run pm2:status",
    "logs": "npm run pm2:logs",
    "tail": "npm run pm2:tail",
    "save": "npm run pm2:save",
    "boot": "npm run pm2:startup",
    "del": "npm run pm2:delete"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
